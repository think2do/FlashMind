<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- TOP: App Name Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="36dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FFFFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:shadowColor="#44000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitle"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <!-- 无障碍引导提示：未开启时显示 -->
        <TextView
            android:id="@+id/btnEnableAccessibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ 开启三击音量键快速录音"
            android:textColor="#AAFFFFFF"
            android:textSize="11sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:background="@drawable/bg_manual_btn"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- MIDDLE: Card Carousel（缩短 30% 高度，上下各加 margin） -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="36dp"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="48dp"
        android:clipToPadding="false"
        android:clipChildren="false" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        android:layout_marginTop="36dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="按住下方按钮\n开始录制灵感"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

    <!-- BOTTOM: Combined Action Bar Section -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="40dp"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dots Indicator (moved here to avoid overlapping cards) -->
        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="14dp" />

        <!-- 小状态提示行（AI 处理中） -->
        <LinearLayout
            android:id="@+id/processingHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="10dp">

            <ProgressBar
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:indeterminate="true"
                android:indeterminateTint="#AAFFFFFF" />

            <TextView
                android:id="@+id/tvLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI 正在生成文案…"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- Recording wave animation -->
        <View
            android:id="@+id/recordingWave"
            android:layout_width="80dp"
            android:layout_height="4dp"
            android:background="@drawable/bg_wave"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <!-- Combined Pill: 录音 | 手动记录（宽度缩短 35%） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:layout_marginHorizontal="84dp"
            android:background="@drawable/bg_bottom_action_bar">

            <!-- Left: Record Section -->
            <LinearLayout
                android:id="@+id/btnRecordSection"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/btnRecord"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_mic"
                    android:scaleType="centerInside" />

                <TextView
                    android:id="@+id/tvRecordHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击录音"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="#44FFFFFF" />

            <!-- Right: Manual Section -->
            <LinearLayout
                android:id="@+id/btnManualSection"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_add_circle"
                    android:scaleType="centerInside" />

                <TextView
                    android:id="@+id/btnManualAdd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="手动记录"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
